{
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "dist/backend",
      "codebase": "default",
      "runtime": "nodejs22",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npx nx build backend",
        "cp backend/.env dist/backend/.env",
        "cp atom-credentials.json dist/backend/atom-credentials.json 2>/dev/null || true"
      ]
    }
  ],
  "hosting": {
    "public": "dist/apps/frontend/browser",
    "predeploy": [
      "npx nx build frontend"
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}